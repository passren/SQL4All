{
  "databases": {
    "athena": {
      "icon": "icons/athena.svg",
      "driver": "pyathena",
      "default_port": 443,
      "dialects": ["awsathena+rest"],
      "uri_template": "dialect://[username[:password]@]host[:port]/[database][?additionalParameters]"
    },
    "bigquery": {
      "icon": "icons/bigquery.svg",
      "driver": "sqlalchemy-bigquery",
      "default_port": 443,
      "dialects": ["bigquery"],
      "uri_template": "dialect://host[/database][?additionalParameters]"
    },
