{
  "name": "sql4all",
  "displayName": "SQL4ALL",
  "description": "Query NoSQL Database using SQL syntax",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sql4all.openQueryPanel",
        "title": "SQL4ALL: Open Query Panel",
        "category": "SQL4ALL",
        "icon": "$(database)"
      },
      {
        "command": "sql4all.addConnection",
        "title": "SQL4ALL: Add Connection",
        "category": "SQL4ALL",
        "icon": "$(add)"
      },
      {
        "command": "sql4all.connectConnection",
        "title": "SQL4ALL: Connect",
        "category": "SQL4ALL",
        "icon": "$(plug)"
      },
      {
        "command": "sql4all.editConnection",
        "title": "SQL4ALL: Edit Connection",
        "category": "SQL4ALL",
        "icon": "$(edit)"
      },
      {
        "command": "sql4all.deleteConnection",
        "title": "SQL4ALL: Delete Connection",
        "category": "SQL4ALL",
        "icon": "$(trash)"
      },
      {
        "command": "sql4all.refreshConnections",
        "title": "SQL4ALL: Refresh Connections",
        "category": "SQL4ALL",
        "icon": "$(refresh)"
      },
      {
        "command": "sql4all.selectPythonExecutable",
        "title": "SQL4ALL: Select Python Executable",
        "category": "SQL4ALL",
        "icon": "$(symbol-namespace)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sql4all-explorer",
          "title": "SQL4ALL",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "sql4all-explorer": [
        {
          "id": "sql4all.connections",
          "name": "Connections",
          "icon": "$(database)",
          "when": "true"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sql4all.addConnection",
          "when": "view == sql4all.connections",
          "group": "navigation@1"
        },
        {
          "command": "sql4all.refreshConnections",
          "when": "view == sql4all.connections",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "sql4all.connectConnection",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "inline@1"
        },
        {
          "command": "sql4all.editConnection",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "inline@2"
        },
        {
          "command": "sql4all.deleteConnection",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "inline@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sql4all.openQueryPanel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "SQL4ALL",
      "properties": {
        "sql4all.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to Python executable used by SQL4ALL to create and manage its venv. Example: C:/Users/<user>/AppData/Local/Programs/Python/Python311/python.exe"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
