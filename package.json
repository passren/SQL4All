{
  "name": "sql4all",
  "displayName": "SQL4ALL",
  "publisher": "sql4all",
  "description": "Query SQL/NoSQL Database using SQL syntax — powered by SQLAlchemy",
  "version": "0.3.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Data Science",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "sql",
    "nosql",
    "database",
    "query",
    "sql client",
    "database management",
    "developer tools",
    "postgresql",
    "mysql",
    "sqlite",
    "mongodb",
    "oracle",
    "snowflake",
    "bigquery",
    "duckdb",
    "mariadb",
    "mssql",
    "clickhouse",
    "redshift",
    "databricks",
    "aws athena",
    "aws dynamodb"
  ],
  "galleryBanner": {
    "color": "#2563EB",
    "theme": "dark"
  },
  "icon": "media/icons/sql4all-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/passren/SQL4All"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sql4all.openQueryPanel",
        "title": "SQL4ALL: Open Query Panel",
        "category": "SQL4ALL",
        "icon": "$(database)"
      },
      {
        "command": "sql4all.addConnection",
        "title": "Add Connection",
        "category": "SQL4ALL",
        "icon": "$(add)"
      },
      {
        "command": "sql4all.connectConnection",
        "title": "Open SQL Executor",
        "category": "SQL4ALL",
        "icon": "$(play)"
      },
      {
        "command": "sql4all.editConnection",
        "title": "Edit Connection...",
        "category": "SQL4ALL",
        "icon": "$(edit)"
      },
      {
        "command": "sql4all.deleteConnection",
        "title": "Delete Connection...",
        "category": "SQL4ALL",
        "icon": "$(trash)"
      },
      {
        "command": "sql4all.refreshConnections",
        "title": "Refresh Connections",
        "category": "SQL4ALL",
        "icon": "$(refresh)"
      },
      {
        "command": "sql4all.selectPythonExecutable",
        "title": "SQL4ALL: Select Python Executable",
        "category": "SQL4ALL",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "sql4all.reloadDriver",
        "title": "Reload Driver",
        "category": "SQL4ALL",
        "icon": "$(sync)"
      },
      {
        "command": "sql4all.copyTableName",
        "title": "Copy Table Name",
        "category": "SQL4ALL",
        "icon": "$(copy)"
      },
      {
        "command": "sql4all.connectDatabase",
        "title": "Connect...",
        "category": "SQL4ALL",
        "icon": "$(plug)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sql4all-explorer",
          "title": "SQL4ALL",
          "icon": "media/icons/sql4all-activitybar.svg"
        }
      ]
    },
    "views": {
      "sql4all-explorer": [
        {
          "id": "sql4all.connections",
          "name": "Connections",
          "icon": "$(database)",
          "when": "true"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sql4all.addConnection",
          "when": "view == sql4all.connections",
          "group": "navigation@1"
        },
        {
          "command": "sql4all.refreshConnections",
          "when": "view == sql4all.connections",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "sql4all.connectConnection",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "inline@1"
        },
        {
          "command": "sql4all.connectDatabase",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "1_connect@1"
        },
        {
          "command": "sql4all.editConnection",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "2_manage@1"
        },
        {
          "command": "sql4all.deleteConnection",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "2_manage@2"
        },
        {
          "command": "sql4all.reloadDriver",
          "when": "view == sql4all.connections && viewItem == sql4all.connectionItem",
          "group": "3_driver@1"
        },
        {
          "command": "sql4all.copyTableName",
          "when": "view == sql4all.connections && viewItem == sql4all.tableItem",
          "group": "inline@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sql4all.openQueryPanel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "SQL4ALL",
      "properties": {
        "sql4all.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to Python executable used by SQL4ALL to create and manage its venv. Example: C:/Users/<user>/AppData/Local/Programs/Python/Python311/python.exe"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
